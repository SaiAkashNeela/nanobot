# ==============================================================================
#                      nanobot Environment Configuration Template
# ==============================================================================
# Copy this file to '.env' to configure your local/production instance:
#   $ cp .env.example .env
#
# Pydantic Settings Mappings:
# All nested configurations in Pydantic can be set using environment variables
# prefixed with 'NANOBOT_' and nested keys separated by double underscores '__'.
# E.g., `agents.defaults.model` becomes `NANOBOT_AGENTS__DEFAULTS__MODEL`.
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. CORE GATEWAY & SYSTEM SETTINGS
# ------------------------------------------------------------------------------
# Timezone for agent cron/wakeups (IANA format, e.g. Asia/Kolkata, America/New_York)
NANOBOT_AGENTS__DEFAULTS__TIMEZONE=UTC

# Workspace directory for agent files, configurations, templates, and logs
NANOBOT_AGENTS__DEFAULTS__WORKSPACE=~/.nanobot/workspace

# Gateway server host and port (used for WebUI / WebSocket communication)
NANOBOT_GATEWAY__HOST=127.0.0.1
NANOBOT_GATEWAY__PORT=18790

# OpenAI-compatible API server host and port (for programmatic REST access)
NANOBOT_API__HOST=127.0.0.1
NANOBOT_API__PORT=8900
NANOBOT_API__TIMEOUT=120.0

# ------------------------------------------------------------------------------
# 2. DEFAULT AGENT BEHAVIOR & LLM PRESETS
# ------------------------------------------------------------------------------
# Default LLM provider name ("auto" for auto-detection based on model prefix, or
# explicit: "gemini", "anthropic", "openai", "openrouter", "deepseek", "groq")
NANOBOT_AGENTS__DEFAULTS__PROVIDER=auto

# Default active model to use for chat turns
NANOBOT_AGENTS__DEFAULTS__MODEL=anthropic/claude-opus-4-5

# Sampling temperature (lower = more deterministic, higher = more creative)
NANOBOT_AGENTS__DEFAULTS__TEMPERATURE=0.1

# Maximum generation tokens allowed per turn
NANOBOT_AGENTS__DEFAULTS__MAX_TOKENS=8192

# Total context window tokens (inputs + outputs combined)
NANOBOT_AGENTS__DEFAULTS__CONTEXT_WINDOW_TOKENS=65536

# Maximum number of nested tool-calling turns before the agent stops
NANOBOT_AGENTS__DEFAULTS__MAX_TOOL_ITERATIONS=200

# Share a single session across all channels (True/False)
NANOBOT_AGENTS__DEFAULTS__UNIFIED_SESSION=false

# Auto-compaction idle threshold in minutes (0 = disabled, e.g., 30 = compact after 30 mins idle)
NANOBOT_AGENTS__DEFAULTS__SESSION_TTL_MINUTES=0

# Max messages to replay from session history (respects token budget limits)
NANOBOT_AGENTS__DEFAULTS__MAX_MESSAGES=120

# ------------------------------------------------------------------------------
# 3. MEMORY & CONSOLIDATION (DREAM)
# ------------------------------------------------------------------------------
# Interval in hours between dream consolidation runs (Phase 1/Phase 2 memory)
NANOBOT_AGENTS__DEFAULTS__DREAM__INTERVAL_H=2

# Maximum entries compacted into a single batch
NANOBOT_AGENTS__DEFAULTS__DREAM__MAX_BATCH_SIZE=20

# Maximum agent steps/tool execution rounds per Dream Phase 2 consolidation
NANOBOT_AGENTS__DEFAULTS__DREAM__MAX_ITERATIONS=15

# Whether to annotate git line-blame ages in Phase 1 memory generation
NANOBOT_AGENTS__DEFAULTS__DREAM__ANNOTATE_LINE_AGES=true

# ------------------------------------------------------------------------------
# 4. LLM PROVIDERS API KEYS & CONFIGURATIONS
# ------------------------------------------------------------------------------
# --- Google Gemini ---
NANOBOT_PROVIDERS__GEMINI__API_KEY=

# --- Anthropic ---
NANOBOT_PROVIDERS__ANTHROPIC__API_KEY=

# --- OpenAI / Custom OpenAI-compatible ---
NANOBOT_PROVIDERS__OPENAI__API_KEY=
NANOBOT_PROVIDERS__OPENAI__API_BASE=
# NANOBOT_PROVIDERS__CUSTOM__API_KEY=
# NANOBOT_PROVIDERS__CUSTOM__API_BASE=

# --- DeepSeek ---
NANOBOT_PROVIDERS__DEEPSEEK__API_KEY=

# --- OpenRouter ---
NANOBOT_PROVIDERS__OPENROUTER__API_KEY=

# --- Groq ---
NANOBOT_PROVIDERS__GROQ__API_KEY=

# --- AWS Bedrock ---
NANOBOT_PROVIDERS__BEDROCK__REGION=us-east-1
NANOBOT_PROVIDERS__BEDROCK__PROFILE=default

# --- Local & Localhost Backends (Ollama, LM Studio) ---
NANOBOT_PROVIDERS__OLLAMA__API_BASE=http://localhost:11434
NANOBOT_PROVIDERS__LM_STUDIO__API_BASE=http://localhost:1234/v1

# ------------------------------------------------------------------------------
# 5. CHANNELS (TELEGRAM, SLACK, WEBSOCKET, ETC.)
# ------------------------------------------------------------------------------
# Enable the local websocket gateway channel
NANOBOT_CHANNELS__WEBSOCKET__ENABLED=true

# --- Telegram Bot ---
NANOBOT_CHANNELS__TELEGRAM__ENABLED=false
NANOBOT_CHANNELS__TELEGRAM__TOKEN=YOUR_TELEGRAM_BOT_TOKEN
# JSON array containing list of allowed Telegram user IDs
NANOBOT_CHANNELS__TELEGRAM__ALLOW_FROM=["YOUR_TELEGRAM_USER_ID"]

# --- Slack Bot ---
NANOBOT_CHANNELS__SLACK__ENABLED=false
NANOBOT_CHANNELS__SLACK__BOT_TOKEN=xoxb-your-slack-bot-token
NANOBOT_CHANNELS__SLACK__APP_TOKEN=xapp-your-slack-app-token

# ------------------------------------------------------------------------------
# 6. TOOL SETTINGS & SECURITY
# ------------------------------------------------------------------------------
# Restrict all file operations and commands to the workspace folder (true/false)
NANOBOT_TOOLS__RESTRICT_TO_WORKSPACE=false

# Web Search integration settings
# Supported providers: "duckduckgo", "tavily", "brave", "jina", "kagi", "olostep"
NANOBOT_TOOLS__WEB__SEARCH__PROVIDER=duckduckgo
NANOBOT_TOOLS__WEB__SEARCH__API_KEY=

# Optional custom Brave search or Jina API keys (if not configured on the provider level above)
# BRAVE_API_KEY=
# TAVILY_API_KEY=
# JINA_API_KEY=

# CIDR IP ranges whitelisted from outbound SSRF blocking (e.g. for Tailscale or intranet)
NANOBOT_TOOLS__SSRF_WHITELIST=["100.64.0.0/10"]

# ------------------------------------------------------------------------------
# 7. SIDECAR DATABASES & INTEGRATIONS
# ------------------------------------------------------------------------------
# PostgreSQL (requires pgvector for semantic memory/embeddings)
POSTGRES_URL=postgresql://nanobot:nanobot_password@localhost:5432/nanobot

# Redis (for caching, queueing, and fast metadata persistence)
REDIS_URL=redis://localhost:6379/0

# MongoDB (for document/session persistence and telemetry logs)
MONGO_URL=mongodb://nanobot:nanobot_password@localhost:27017/nanobot?authSource=admin
